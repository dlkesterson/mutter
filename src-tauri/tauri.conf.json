{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mutter",
  "version": "0.1.0",
  "identifier": "com.dlkesterson.mutter",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5755",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "mutter",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src 'self' blob: mediastream:; connect-src 'self' ipc: http://ipc.localhost http://localhost:8080; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/embedding-server"
    ]
  }
}
