{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mutter",
  "version": "0.3.0",
  "identifier": "com.dlkesterson.mutter",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5755",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "mutter",
        "decorations": false,
        "transparent": true,
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src 'self' blob: mediastream:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:* https://api.anthropic.com https://api.openai.com ws://localhost:* ws://127.0.0.1:* wss://*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/embedding-server",
      "binaries/sync-server"
    ]
  }
}
