            CommandIntent {
                id: "editor_redo".to_string(),
                phrases: vec![
                    "redo".to_string(),
                    "redo that".to_string(),
                    "go forward".to_string(),
                ],
                embedding: vec![],
                action: CommandAction::Editor(EditorAction::Redo),
